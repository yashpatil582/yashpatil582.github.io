# Copy to .env.local (dev) or set in your host's secret store. NEVER commit real
# values. Only NEXT_PUBLIC_* vars reach the browser — everything else is
# server-side only. Stage 0 (the static site) needs nothing here except the URL.

# ---- Site ----
# Canonical URL once a custom domain is live, e.g. https://yashpatil.dev
NEXT_PUBLIC_SITE_URL=

# ====================================================================
# Stage 1 — "Chat with Yash" RAG agent. All server-side. Names only;
# fill values in .env.local or your host. See README for where each is used.
# ====================================================================

# Provider-agnostic model adapter. Default = open weights via Groq
# (OpenAI-compatible). Swap AI_PROVIDER/AI_MODEL to use a closed API instead.
AI_PROVIDER=groq
AI_MODEL=openai/gpt-oss-120b
# Second open-weight model tried automatically if the primary is unavailable.
AI_FALLBACK_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# Optional closed-API swaps (leave blank to stay fully open-weight). AI_BASE_URL
# is only needed when AI_PROVIDER=openai-compatible (any OpenAI-compatible host).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_BASE_URL=

# Embeddings. Default = local in-process open model (BGE) — no key needed.
# Docs are embedded at ingest time; the user query is embedded at runtime.
# Set EMBEDDINGS_PROVIDER=hosted only if you don't want to run embeddings locally.
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=Xenova/bge-small-en-v1.5
TOGETHER_API_KEY=
HF_API_TOKEN=

# Postgres + pgvector (Supabase, or the local docker-compose db). One URL works
# for both: local = postgres://postgres:postgres@localhost:5432/portfolio
DATABASE_URL=

# Cloudflare Turnstile bot check. The SITE key is public by design; the SECRET
# is verified server-side and must never reach the browser. The values below are
# Cloudflare's documented TEST keys (always pass) — replace with real keys in prod.
# Always-fail secret for testing the reject path: 2x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Request guards (non-secret config).
ALLOWED_ORIGINS=http://localhost:3000
MODEL_ALLOWLIST=openai/gpt-oss-120b,llama-3.3-70b-versatile
MAX_OUTPUT_TOKENS=512
# Global daily request cap = the spend backstop. Size it to the Groq free-tier
# tokens-per-day for your model (each request ≈ 1–2K tokens at MAX_OUTPUT_TOKENS=512).
GLOBAL_DAILY_CAP=300

# ====================================================================
# Stage 2 — MCP "Explore any repo" agent. All server-side. The agent
# explores PUBLIC GitHub repos via real MCP tools and shares the same
# model adapter + security envelope as Chat. Nothing here is required to
# run locally; the defaults below are safe.
# ====================================================================

# Optional GitHub token (server-side ONLY — never reaches the browser). Raises
# the GitHub API limit from 60/hr (unauthenticated) to 5000/hr. A fine-grained
# token with PUBLIC-repo read access is plenty; recommended in production.
GITHUB_TOKEN=

# Repo-agent abuse caps (env-overridable; defaults shown). The agent fans out to
# several model steps + GitHub calls per request, so these are tighter than chat.
REPO_AGENT_MAX_STEPS=6
REPO_AGENT_MAX_FILES=4
REPO_AGENT_MAX_BYTES=131072
REPO_AGENT_MAX_FILE_BYTES=16384
REPO_AGENT_MAX_TREE_ENTRIES=400
REPO_AGENT_TIMEOUT_MS=8000
REPO_AGENT_MAX_OUTPUT_TOKENS=768

# Route-scoped rate limits. Per-IP limits are namespaced to this route; the
# repo global sub-cap and the shared GLOBAL_DAILY_CAP backstop still apply.
RL_REPO_PER_IP_PER_MIN=3
RL_REPO_PER_IP_PER_DAY=20
RL_REPO_GLOBAL_DAILY=150
